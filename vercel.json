{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/portal/api/:path*", "destination": "/api/:path*" },
    { "source": "/", "destination": "/portal/index.html" },
    { "source": "/portal", "destination": "/portal/index.html" },
    { "source": "/portal/:path*", "destination": "/portal/index.html" }
  ]
}
