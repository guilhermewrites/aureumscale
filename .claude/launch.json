      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5200", "--directory", "/Users/guilherme/Desktop/[ROAS] - [Webinar Funnel]"],
      "port": 5200
    },
    {
      "name": "Aureum Funnel",
      "runtimeExecutable": "python3",
